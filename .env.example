# ───────────────────────────────────────────────────────────────
# Lumen — Marketing Intelligence Platform
# Copy to .env.local for local dev, set in EdgeOne dashboard for prod.
# ───────────────────────────────────────────────────────────────

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apify (https://console.apify.com/account/integrations)
APIFY_TOKEN=

# Apify actor IDs (defaults below are public community actors — replace with your own)
APIFY_ACTOR_INSTAGRAM_PROFILE=apify/instagram-profile-scraper
APIFY_ACTOR_INSTAGRAM_POSTS=apify/instagram-post-scraper
APIFY_ACTOR_LINKEDIN_PROFILE=apify/linkedin-profile-scraper

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# App
NEXT_PUBLIC_APP_NAME=Lumen
NEXT_PUBLIC_APP_URL=http://localhost:3000
